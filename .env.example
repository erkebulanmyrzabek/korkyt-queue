APP_ENV=development
DEBUG=true
PROJECT_NAME=Korkyt Queue
API_PREFIX=/api/v1
SECRET_KEY=change-me-before-production
DEFAULT_LANGUAGE=ru

POSTGRES_DB=korkyt_queue
POSTGRES_USER=korkyt
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://korkyt:change-me@postgres:5432/korkyt_queue

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

BOT_TOKEN=replace-with-real-token
BOT_PARSE_MODE=HTML

MEDIA_ROOT=/data/uploads
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173
VITE_API_BASE=/api/v1
VITE_APP_TITLE=Korkyt Queue
VITE_DEV_PROXY_TARGET=http://api:8000

NGINX_PORT=8080
API_PORT=8000
FRONTEND_PORT=5173
